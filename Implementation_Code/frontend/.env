# ─── AWS Cognito ───────────────────────────────────────────────
# Replace with your Cognito User Pool ID from AWS Console
# Found at: Cognito → User Pools → ai-tutor-user-pool → Pool ID
# Format: <region>_<pool-id>  e.g. ap-south-1_AbCdEfGhI
VITE_COGNITO_USER_POOL_ID=ap-south-1_aQv5iCalF

# Replace with your Cognito App Client ID from AWS Console
# Found at: Cognito → User Pools → ai-tutor-user-pool → App integration → App clients
# Format: alphanumeric string  e.g. 1abc2def3ghi4jkl5mno6pqr
VITE_COGNITO_CLIENT_ID=ho62bu6a7q9uf4hhpegvdeocb

# ─── API Gateway ───────────────────────────────────────────────
# Replace with your API Gateway invoke URL from AWS Console
# Found at: API Gateway → ai-tutor-api → Stages → prod → Invoke URL
# Format: https://<api-id>.execute-api.<region>.amazonaws.com/prod
# In dev: LEAVE THIS COMMENTED OUT — Vite proxy (vite.config.js) handles routing to AWS, bypassing CORS
# In production deployment: uncomment and set to your full AWS API Gateway URL
VITE_API_URL=https://d5laro127a.execute-api.ap-south-1.amazonaws.com/prod
S3_BUCKET_NAME = ai-tutor-materials-2
BEDROCK_MODEL_ID = us.amazon.nova-lite-v1:0
TABLE_PREFIX = ai-tutor
SNS_TOPIC_ARN = arn:aws:sns:ap-south-1:661000947583:ai-tutor-notifications